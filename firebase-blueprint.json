{
  "entities": {
    "Incident": {
      "title": "Incident Report",
      "description": "A community-submitted incident report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["crime", "traffic", "infrastructure", "weather"] },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "timestamp": { "type": "number" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "verified_status": { "type": "string", "enum": ["unverified", "multiple_reports", "community_confirmed"] },
        "image_url": { "type": "string", "format": "uri" },
        "report_count": { "type": "number" },
        "authorUid": { "type": "string" }
      },
      "required": ["title", "description", "category", "lat", "lng", "timestamp", "email", "name", "verified_status", "authorUid"]
    },
    "CommunityStats": {
      "title": "Community Statistics",
      "description": "Historical crime data for a specific community.",
      "type": "object",
      "properties": {
        "community": { "type": "string" },
        "month": { "type": "string" },
        "violent_crime": { "type": "number" },
        "property_crime": { "type": "number" },
        "disorder_calls": { "type": "number" },
        "safety_score": { "type": "number" }
      },
      "required": ["community", "month", "violent_crime", "property_crime", "disorder_calls", "safety_score"]
    },
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "displayName", "email", "role"]
    }
  },
  "firestore": {
    "incidents/{incidentId}": {
      "schema": { "$ref": "Incident" },
      "description": "Collection of live incident reports."
    },
    "community_stats/{statsId}": {
      "schema": { "$ref": "CommunityStats" },
      "description": "Collection of historical community crime statistics."
    },
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Collection of user profiles."
    }
  }
}
